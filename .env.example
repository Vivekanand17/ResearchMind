MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# Optional model/behavior
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT_SECS=60
MISTRAL_MAX_RETRIES=6
MISTRAL_RETRY_MIN_SECS=2
MISTRAL_RETRY_MAX_SECS=60
MISTRAL_DISABLE_RETRIES=false

TAVILY_MAX_RESULTS=5
TAVILY_SNIPPET_MAX_CHARS=300

SCRAPE_TIMEOUT_SECS=10
SCRAPE_MAX_CHARS=3000

# Writer/Critic sizing
PROMPT_RESEARCH_MAX_CHARS=18000
PROMPT_REPORT_MAX_CHARS=14000

